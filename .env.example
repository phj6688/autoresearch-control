# Required — path to cloned autoresearch repo
AUTORESEARCH_REPO_PATH=/home/lumo/autoresearch_foundation/autoresearch

# Required — directory where git worktrees are created
AUTORESEARCH_WORKTREE_DIR=/home/lumo/autoresearch_foundation/autoresearch-runs

# Server port (default 3100)
PORT=3200

# Telegram alerts (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Default agent type
DEFAULT_AGENT=claude-code

# Default agent spawn command
DEFAULT_AGENT_COMMAND=claude --model claude-opus-4-6

# Additional args for claude code
CLAUDE_CODE_ARGS=--print

# CLIProxyAPI gateway (required for in-app chat assistant)
CLIPROXY_GATEWAY_URL=http://100.79.164.120:18789
CLIPROXY_GATEWAY_TOKEN=
ASSISTANT_MODEL=anthropic/claude-haiku-4-5
